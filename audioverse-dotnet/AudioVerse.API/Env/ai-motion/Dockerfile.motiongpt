FROM python:3.11-slim

WORKDIR /app
RUN pip install --no-cache-dir fastapi uvicorn pydantic numpy

# Clone MotionGPT repo & install
RUN apt-get update && apt-get install -y git && \
    git clone --depth 1 https://github.com/OpenMotionLab/MotionGPT.git /opt/motiongpt && \
    pip install --no-cache-dir -r /opt/motiongpt/requirements.txt 2>/dev/null || true && \
    apt-get remove -y git && apt-get autoremove -y && rm -rf /var/lib/apt/lists/*

ENV PYTHONPATH="/opt/motiongpt:${PYTHONPATH}"

COPY motiongpt/app.py /app/app.py

EXPOSE 8300
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8300"]
