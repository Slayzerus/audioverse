## 6. Sugestie implementacji na froncie

### Wyświetlanie okładki — priorytet

```tsx
const getCoverUrl = (song: KaraokeSongDto): string | null => {
  return song.linkedSong?.albumCoverUrl
      ?? song.linkedSong?.externalCoverUrl
      ?? song.externalCoverUrl
      ?? (song.coverPath ? `/covers/${song.coverPath}` : null);
};
```

### Wyświetlanie linków streamingowych

```tsx
{song.linkedSong?.streamingLinks.map(link => (
  <a key={link} href={link} target="_blank" rel="noopener noreferrer">
    {link.includes('spotify') ? '🎵 Spotify' : link.includes('youtube') ? '▶️ YouTube' : '🔗 Link'}
  </a>
))}
```

### Czas trwania — formatowanie

```tsx
const formatDuration = (sec: number | null | undefined): string => {
  if (!sec) return '—';
  const m = Math.floor(sec / 60);
  const s = sec % 60;
  return `${m}:${s.toString().padStart(2, '0')}`;
};

// Użycie:
<span>{formatDuration(song.linkedSong?.durationSeconds)}</span>
```

### Wyszukiwarka z debounce i nowymi filtrami

```tsx
const [filter, setFilter] = useState<SongFilterRequest>({
  searchQuery: '',
  includeLinkedSongDetails: true,
  page: 1,
  pageSize: 20,
});

useEffect(() => {
  if ((filter.searchQuery?.length ?? 0) < 2 && !filter.genres?.length) return;
  const timer = setTimeout(() => {
    fetch('/api/karaoke/get-filtered-songs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
      body: JSON.stringify(filter),
    })
      .then(r => r.json())
      .then(data => setSongs(data.items));
  }, 300);
  return () => clearTimeout(timer);
}, [filter]);
```

