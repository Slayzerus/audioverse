# === AudioVerse React — Environment Variables ===
#
# Copy this file to .env.local and fill in the values.
# Vite variables must be prefixed with VITE_.
#

# ── API ─────────────────────────────────────────────────────────
# Base URL of the AudioVerse backend API.
VITE_AUDIOVERSE_API_ROOT=https://localhost:5001

# ── Telemetry / Navigation Logger ──────────────────────────────
# Optional: analytics endpoint for spatial navigation telemetry.
# If not set, NavigationLogger only writes to console (dev mode) or is silent.
# VITE_NAV_ANALYTICS_ENDPOINT=https://analytics.example.com/nav
# VITE_NAV_ERROR_ENDPOINT=https://analytics.example.com/nav-errors

# ── Google Analytics (optional) ────────────────────────────────
# Set this if you want gtag.js to be loaded.
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# ── Sentry (optional) ─────────────────────────────────────────
# Set this if you want Sentry error tracking.
# VITE_SENTRY_DSN=https://xxx@sentry.io/123
