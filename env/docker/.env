# -------- Global / network --------
COMPOSE_PROJECT_NAME=proj-core
NETWORK_NAME=audioverse-net
# Profile opcjonalne (u nas tylko video korzysta z profiles)
COMPOSE_PROFILES=core,aiaudio,aivideo

# -------- Host paths (Windows; forward slashes!) --------
HOST_ROOT=C:/Home/AudioVerse
HOST_CONF_DIR=./nginx
HOST_CERTS_DIR=./nginx/certs
HOST_DATA_DIR=${HOST_ROOT}/data
HOST_DB_DIR=${HOST_DATA_DIR}/postgres
HOST_REDIS_DIR=${HOST_DATA_DIR}/redis
HOST_HTTPS_DIR=${HOST_ROOT}/https

# -------- Ports (host side) --------
ADMINER_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

API_HTTP=5000
API_HTTPS=5001
IDENTITY_HTTP=5002
IDENTITY_HTTPS=5003
LIBRARY_HTTP=5004
LIBRARY_HTTPS=5005

WEB_HTTP=8081
WEB_HTTPS=8443

# -------- Images (zmień, jeśli potrzebujesz) --------
IMAGE_API=slayzer/audioverse-api:latest
IMAGE_IDENTITY=slayzer/audioverse-identity:latest
IMAGE_LIBRARY=slayzer/resource-library-api:latest
IMAGE_REACT=slayzer/audioverse-react:latest

# -------- AI Audio (publiczne obrazy + porty) --------
ASR_FW_PORT=8000
ASR_VOSK_PORT=8020
PIPER_HTTP=5006
OPENTTS_HTTP=5500
IMAGE_ASR_FW=fedirz/faster-whisper-server:latest-cpu
IMAGE_TTS_PIPER=artibex/piper-http:latest
IMAGE_OPENTTS=synesthesiam/opentts:latest

# -------- Lokalne katalogi AI (Twoje ./ai/...) --------
AI_DIR=./ai
VITPOSE_MODELS_DIR=${AI_DIR}/vitpose/models
POSEFORMER_MODELS_DIR=${AI_DIR}/poseformer/models
OPENPOSE_MODELS_DIR=${AI_DIR}/openpose/models
ALPHAPOSE_MODELS_DIR=${AI_DIR}/alphapose/models
MEDIAPIPE_MODELS_DIR=${AI_DIR}/mediapipe/models

# --- Video ports (host) ---
MEDIAPIPE_HTTP=8101
OPENPOSE_HTTP=8102
ALPHAPOSE_HTTP=8103
VITPOSE_HTTP=8104
POSEFORMER_HTTP=8105


# -------- AI Video (jeśli chcesz obrazy zamiast build, odkomentuj i ustaw) --------
# VIDEO_MEDIAPIPE_IMAGE=ghcr.io/videodev/mediapipe-http:latest
# VIDEO_OPENPOSE_IMAGE=ghcr.io/videodev/openpose-http:latest
# VIDEO_ALPHAPOSE_IMAGE=ghcr.io/videodev/alphapose-http:latest
# VIDEO_VITPOSE_IMAGE=ghcr.io/videodev/vitpose-http:latest
# VIDEO_POSEFORMER_IMAGE=ghcr.io/videodev/poseformer-http:latest

# Jeśli budujesz lokalnie z drzewa ./ai:
VIDEO_OPENPOSE_IMAGE=local/openpose-http:dev
VIDEO_OPENPOSE_BUILD_CONTEXT=./ai/openpose

# -------- ASP.NET cert (jeśli używasz Kestrel HTTPS) --------
ASPNETCORE_CERT_PASSWORD=changeit
